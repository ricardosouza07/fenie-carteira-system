# Exemplo de variaveis para producao interna da Fenie.
# Nao copie chaves reais para este arquivo. Configure segredos no painel da Vercel
# e no Supabase remoto.

# Aplicacao
NEXT_PUBLIC_APP_NAME="Central de Carteira Fenie PRO"
NEXT_PUBLIC_APP_ENV="production"

# Supabase remoto
# URL publica do projeto Supabase de producao.
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"

# Chave anon/publica do Supabase. Pode ficar no browser, mas ainda deve ser
# tratada como configuracao do ambiente correto.
NEXT_PUBLIC_SUPABASE_ANON_KEY="<supabase-anon-key>"

# Chave service_role do Supabase. Segredo server-side usado somente por Server
# Actions administrativas, como publicacao de importacoes.
SUPABASE_SERVICE_ROLE_KEY="<supabase-service-role-key>"

# Opcional para scripts administrativos fora do frontend.
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_ANON_KEY="<supabase-anon-key>"

# Vercel/CI, se houver deploy por pipeline manual.
# Na integracao GitHub da Vercel estes valores normalmente nao sao necessarios.
VERCEL_TOKEN="<vercel-token>"
VERCEL_ORG_ID="<vercel-org-id>"
VERCEL_PROJECT_ID="<vercel-project-id>"
